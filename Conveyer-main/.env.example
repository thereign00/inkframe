# All keys can also be set through the UI at /settings.
# Anything here is used as a fallback when the corresponding DB row is empty.

# ── Required ──────────────────────────────────────────────
# Gemini for scene splitting. Get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# 69labs.vip — covers TTS + images + video animation. Starts with vk_
LABS69_API_KEY=

# ── Optional / backup providers ───────────────────────────
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=

# Absolute path to ffmpeg if it isn't already in your PATH.
# Windows example: C:\\ffmpeg\\bin\\ffmpeg.exe
FFMPEG_PATH=

# ── Storage location ──────────────────────────────────────
# Where runs are written. Leave empty to use the default (~/.conveyer-isabell/runs).
# Setting this also recreates the data/runs junction inside the project.
ISABELL_DATA_DIR=
