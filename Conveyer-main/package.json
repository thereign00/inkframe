{
  "name": "inkframe",
  "version": "1.0.8",
  "private": true,
  "author": "Inkframe",
  "main": "electron/dist/main.js",
  "description": "Desktop pipeline platform for AI faceless YouTube videos.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:rebuild": "npx @electron/rebuild -m . --which-module better-sqlite3",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run build && npm run electron:build && node scripts/prepare-electron.mjs && electron .",
    "predist": "npm rebuild better-sqlite3 && npm run build && npm run electron:build && node scripts/prepare-electron.mjs",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
